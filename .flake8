[flake8]
# WPS412 forbids logic in an __init__.py and WPS410 forbids module-level
# metadata such as __all__. Two package initializers deliberately carry
# import-time logic and are scoped exemptions here:
#
# * orchestrator/config/__init__.py invokes the `environment` resolver and
#   binds its results so reloading or patching `orchestrator.config` re-runs
#   resolution into the same namespace the helpers read -- the reload / patch
#   contract this package exists to preserve -- and publishes its narrow
#   public surface through an explicit __all__ (WPS410) in that initializer.
# * orchestrator/agents/__init__.py is the stable agent facade: it re-exports
#   the model types, the runner owner's `run_agent`, and the process owner's
#   `terminate_all_running`, and publishes its narrow public surface through an
#   explicit __all__ (WPS410) so `orchestrator.agents` stays the historical
#   import site. WPS412 is waived for that import-time logic.
# * orchestrator/github/__init__.py is the stable PyGithub client facade: it
#   binds the pinned-state owner eagerly and resolves `GitHubClient` plus the
#   composed mixin re-exports through a module `__getattr__` (WPS413) so a
#   leaf-first import never re-enters a half-built initializer, keeping
#   `orchestrator.github` the historical import site. WPS412 is waived for that
#   import-time logic.
#
# orchestrator/agents/sessions.py is one owner for both JSONL parsing surfaces
# -- session-id extraction and Claude final-message extraction -- and each
# surface decomposes into small single-purpose helpers, so the module carries
# 11 members past the WPS202 ceiling of 7. orchestrator/agents/processes.py is
# one owner for the shared process registry and the subprocess-group lifecycle
# -- registration, bounded draining, timeout classification, and SIGTERM/SIGKILL
# escalation -- so it carries 9 members past the same ceiling. Both single-owner
# groupings are deliberate, so WPS202 is waived for those files.
per-file-ignores =
    orchestrator/config/__init__.py:WPS412,WPS410
    orchestrator/agents/__init__.py:WPS412,WPS410
    orchestrator/github/__init__.py:WPS412,WPS413
    orchestrator/agents/sessions.py:WPS202
    orchestrator/agents/processes.py:WPS202
